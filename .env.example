# ============================================================
# AIB OCR Subsystem — Environment Configuration
# ============================================================
# Скопируйте этот файл в .env и настройте значения

# --- Application ---
APP_ENV=production
APP_SECRET_KEY=CHANGE_ME_USE_RANDOM_64_CHARS
APP_DEBUG=false
APP_TITLE=AIB OCR Subsystem
APP_VERSION=1.0.0

# --- Server ---
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=4

# --- Database (PostgreSQL) ---
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=aib_ocr
POSTGRES_USER=aib_user
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD
DATABASE_URL=postgresql+asyncpg://aib_user:CHANGE_ME_STRONG_PASSWORD@postgres:5432/aib_ocr
DATABASE_URL_SYNC=postgresql://aib_user:CHANGE_ME_STRONG_PASSWORD@postgres:5432/aib_ocr

# --- Redis ---
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
REDIS_URL=redis://redis:6379/0

# --- Celery ---
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1
CELERY_TASK_SOFT_TIME_LIMIT=30
CELERY_TASK_TIME_LIMIT=60
CELERY_MAX_RETRIES=3
CELERY_RETRY_BACKOFF=30

# --- File Storage ---
UPLOAD_DIR=/app/storage/uploads
PROCESSED_DIR=/app/storage/processed
MAX_UPLOAD_SIZE_MB=50
ALLOWED_EXTENSIONS=pdf,jpg,jpeg,png,tiff,tif,bmp

# --- PaddleOCR ---
PADDLE_USE_GPU=false
PADDLE_CPU_THREADS=4
PADDLE_LANG=ru
PADDLE_USE_ANGLE_CLS=true
PADDLE_USE_SPACE_CHAR=true
PADDLE_SHOW_LOG=false

# --- 1С Integration ---
C1_BASE_URL=http://1c-server:80/accounting/hs/docai
C1_USERNAME=docai_service
C1_PASSWORD=CHANGE_ME_1C_PASSWORD
C1_TIMEOUT_SECONDS=10
C1_MAX_RETRIES=3
C1_CIRCUIT_BREAKER_THRESHOLD=3
C1_CIRCUIT_BREAKER_TIMEOUT=60

# --- Security ---
JWT_SECRET_KEY=CHANGE_ME_JWT_SECRET_64_CHARS
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=240
ALLOWED_HOSTS=localhost,127.0.0.1

# --- Logging ---
LOG_LEVEL=INFO
LOG_FORMAT=json
LOG_FILE=/app/logs/aib_ocr.log
